APP_NAME="CRM Comercial Ps-pool"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

SESSION_DRIVER=file
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# API Gesplanet
CRM_API_URL=http://pspool.dyndns.org:10445/ApiGesplanet_TC/public/api/
CRM_API_URL_LOCAL=http://pspool.dyndns.org:10445/ApiGesplanet_TC/public/api/
CRM_API_URL_SERVER=
CRM_API_FALLBACK_URLS=
CRM_API_FALLBACK_URLS_LOCAL=
CRM_API_FALLBACK_URLS_SERVER=
CRM_WS_RH=http://pspool.dyndns.org:10445/Recursos_humanos_TC
CRM_WS_RH_LOCAL=http://pspool.dyndns.org:10445/Recursos_humanos_TC
CRM_WS_RH_SERVER=
CRM_WS_RH_FALLBACK_URLS=
CRM_WS_RH_FALLBACK_URLS_LOCAL=
CRM_WS_RH_FALLBACK_URLS_SERVER=
CRM_COMERCIAL_TECNICO=102
CRM_API_CONNECT_TIMEOUT=10
CRM_API_TRANSPORT=auto
CRM_API_PAYLOAD_FORMAT=form
CRM_API_VERIFY_SSL=true
CRM_API_USER_AGENT="CRM Comercial Ps-pool"
CRM_API_FORCE_IPV4=false
CRM_API_READ_FALLBACK_POST=true

# Base de datos Firebird (opcional, si se conecta directo)
DB_SERVER=
DB_SERVER_RH=
DB_USERNAME=SYSDBA
DB_PASSWORD=masterkey

# Correo
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# Dachser
DACHSER_API_URL=https://comercial.ps-pool.com/dachser_integracion/obtenerURLSeguimiento.php
DACHSER_CODIGO=5

# Imágenes
IMAGES_FOLDER=storage/app/public/imagenes/
IMAGES_URL=/storage/imagenes/
